{
  "manifest_version": 3,
  "name": "ContextCard",
  "version": "0.1.0",
  "description": "AI-powered vocabulary flashcards from real reading",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],

  "background": {
    "service_worker": "background/background.js"
  }
}